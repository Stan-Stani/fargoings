# No API token needed - tokens are fetched dynamically from the website

# Which city this deployment serves (default: fargo).
#CITY=siouxfalls

# Ports — override when two city instances share one box
# (Fargo keeps the defaults; SooGoings uses 8790/8789).
#API_PORT=8788
#WEB_PORT=8787

# Cloudflare Worker relay URLs for WAF'd sources (include the ?key= secret):
# Fargo: westfargolibrary.org iCal + larl.org (Moorhead) Communico API.
#WFPL_ICS_URL=https://wfpl-feed.islaus.workers.dev/?key=...
#MPH_EVENTS_URL=https://larl-feed.islaus.workers.dev/?key=...
# Sioux Falls: siouxlandlib.org Communico API (blocked from ALL non-CF IPs).
#SIOUXLAND_EVENTS_URL=https://siouxland-feed.islaus.workers.dev/?key=...
